# LLM API Keys (choose one or more)
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
ARK_API_KEY=ark-xxx
ARK_EMBEDDING_MODEL=ep-xxxxxxxxxxxxxxxx
ARK_SSL_VERIFY=true
ARK_CA_BUNDLE=

# Neo4j Connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# Model Configuration (per agent)
ROUTER_MODEL=deepseek-chat
GRAPH_QUERY_MODEL=deepseek-coder
OBSTETRICIAN_MODEL=deepseek-chat
ENDOCRINOLOGIST_MODEL=deepseek-chat
REVIEWER_MODEL=deepseek-chat

# Server
HOST=0.0.0.0
PORT=8000
CONSULT_DB_PATH=data/consultations.db
CONSULT_STORE_MAX_RECORDS=5000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
